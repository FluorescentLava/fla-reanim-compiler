<Window
    x:Class="FlaReanimCompiler.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:FlaReanimCompiler"
    Title="FLA Reanim Compiler">

  <NavigationView x:Name="RootNavigation"
                  PaneDisplayMode="Left"
                  IsBackButtonVisible="Collapsed"
                  IsSettingsVisible="False"
                  IsPaneOpen="True"
                  OpenPaneLength="232"
                  CompactPaneLength="48"
                  Background="Transparent">
    <NavigationView.MenuItems>
      <NavigationViewItem Content="转换"
                          IsSelected="True">
        <NavigationViewItem.Icon>
          <FontIcon Glyph="&#xE8B7;" />
        </NavigationViewItem.Icon>
      </NavigationViewItem>
    </NavigationView.MenuItems>

    <NavigationView.PaneFooter>
      <StackPanel Margin="12,0,12,18"
                  Spacing="10">
        <TextBlock Text="格式"
                   Style="{ThemeResource CaptionTextBlockStyle}"
                   Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
        <Grid ColumnSpacing="10"
              RowSpacing="6">
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
          </Grid.RowDefinitions>
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="52" />
            <ColumnDefinition Width="*" />
          </Grid.ColumnDefinitions>

          <TextBlock Text="输入"
                     Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
          <TextBlock Grid.Column="1"
                     Text=".fla / XFL" />
          <TextBlock Grid.Row="1"
                     Text="输出"
                     Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
          <TextBlock Grid.Row="1"
                     Grid.Column="1"
                     Text=".reanim.compiled" />
          <TextBlock Grid.Row="2"
                     Text="缓存"
                     Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
          <TextBlock Grid.Row="2"
                     Grid.Column="1"
                     Text="zlib + schema" />
        </Grid>
      </StackPanel>
    </NavigationView.PaneFooter>

    <Grid Padding="32,28,32,24"
          Background="{ThemeResource LayerFillColorDefaultBrush}">
      <Grid.RowDefinitions>
        <RowDefinition Height="Auto" />
        <RowDefinition Height="14" />
        <RowDefinition Height="Auto" />
        <RowDefinition Height="18" />
        <RowDefinition Height="188" />
        <RowDefinition Height="18" />
        <RowDefinition Height="*" />
      </Grid.RowDefinitions>

      <Grid Grid.Row="0"
            RowSpacing="12">
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto" />
          <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Viewbox MaxHeight="48"
                 HorizontalAlignment="Left"
                 Stretch="Uniform"
                 StretchDirection="DownOnly">
          <TextBlock Text="FLA Reanim Compiler"
                     TextWrapping="NoWrap"
                     TextTrimming="CharacterEllipsis"
                     Style="{ThemeResource TitleTextBlockStyle}" />
        </Viewbox>

        <Grid Grid.Row="1"
              ColumnSpacing="14">
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="Auto" />
          </Grid.ColumnDefinitions>

          <Viewbox MaxHeight="22"
                   HorizontalAlignment="Left"
                   VerticalAlignment="Center"
                   Stretch="Uniform"
                   StretchDirection="DownOnly">
            <TextBlock Text="拖入 .fla 后在原目录生成同名 .reanim.compiled"
                       TextWrapping="NoWrap"
                       TextTrimming="CharacterEllipsis"
                       Style="{ThemeResource BodyTextBlockStyle}"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
          </Viewbox>

          <StackPanel Grid.Column="1"
                      Orientation="Horizontal"
                      HorizontalAlignment="Right"
                      Spacing="8">
            <Button x:Name="PickFilesButton"
                    Content="选择文件"
                    Style="{StaticResource AccentButtonStyle}"
                    Click="PickFiles_Click" />
            <Button x:Name="ClearButton"
                    Content="清空"
                    Click="Clear_Click" />
          </StackPanel>
        </Grid>
      </Grid>

      <InfoBar x:Name="StatusInfoBar"
               Grid.Row="2"
               IsOpen="True"
               Severity="Informational"
               Title="等待文件"
               Message="可以拖放多个 .fla 文件，也可以点击选择文件。" />

      <Border x:Name="DropSurface"
              Grid.Row="4"
              Padding="24"
              Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
              BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}"
              BorderThickness="1"
              CornerRadius="8"
              AllowDrop="True"
              DragOver="DropSurface_DragOver"
              DragLeave="DropSurface_DragLeave"
              Drop="DropSurface_Drop">
        <Grid ColumnSpacing="18">
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="*" />
          </Grid.ColumnDefinitions>

          <Border x:Name="DropIconSurface"
                  Width="56"
                  Height="56"
                  CornerRadius="8"
                  Background="{ThemeResource ControlFillColorSecondaryBrush}"
                  VerticalAlignment="Center">
            <FontIcon Glyph="&#xE8E5;"
                      FontSize="26"
                      Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}" />
          </Border>

          <StackPanel Grid.Column="1"
                      VerticalAlignment="Center"
                      Spacing="6">
            <TextBlock x:Name="DropTitleText"
                       Text="拖放 .fla 文件到这里"
                       Style="{ThemeResource SubtitleTextBlockStyle}" />
            <TextBlock x:Name="DropDetailText"
                       Text="支持多个文件，输出保存在原目录"
                       Style="{ThemeResource BodyTextBlockStyle}"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
            <ProgressBar x:Name="BusyProgress"
                         Width="300"
                         Height="4"
                         HorizontalAlignment="Left"
                         Margin="0,12,0,0"
                         IsIndeterminate="True"
                         Visibility="Collapsed" />
          </StackPanel>
        </Grid>
      </Border>

      <Grid Grid.Row="6">
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto" />
          <RowDefinition Height="10" />
          <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0">
          <TextBlock Text="日志"
                     Style="{ThemeResource SubtitleTextBlockStyle}" />
          <TextBlock Text="最近结果在上方"
                     HorizontalAlignment="Right"
                     VerticalAlignment="Bottom"
                     Style="{ThemeResource CaptionTextBlockStyle}"
                     Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
        </Grid>

        <ListView Grid.Row="2"
                  ItemsSource="{x:Bind LogItems}"
                  SelectionMode="None">
          <ListView.ItemContainerStyle>
            <Style TargetType="ListViewItem">
              <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            </Style>
          </ListView.ItemContainerStyle>
          <ListView.ItemTemplate>
            <DataTemplate x:DataType="local:ConversionLogItem">
              <Border Margin="0,4"
                      Padding="14,12"
                      Background="{x:Bind Background}"
                      BorderBrush="{x:Bind BorderBrush}"
                      BorderThickness="1"
                      CornerRadius="8">
                <Grid ColumnSpacing="12">
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                  </Grid.ColumnDefinitions>
                  <Ellipse Width="8"
                           Height="8"
                           Margin="0,7,0,0"
                           VerticalAlignment="Top"
                           Fill="{x:Bind Accent}" />
                  <StackPanel Grid.Column="1"
                              Spacing="4">
                    <TextBlock Text="{x:Bind Title}"
                               Style="{ThemeResource BodyStrongTextBlockStyle}" />
                    <TextBlock Text="{x:Bind Detail}"
                               TextWrapping="Wrap"
                               Style="{ThemeResource BodyTextBlockStyle}"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                  </StackPanel>
                </Grid>
              </Border>
            </DataTemplate>
          </ListView.ItemTemplate>
        </ListView>
      </Grid>
    </Grid>
  </NavigationView>
</Window>
